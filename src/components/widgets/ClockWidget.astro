---
import Icon from '../Icon.astro';
---

<article
  class="min-h-[210px] p-[30px_28px] overflow-hidden border border-paper-line rounded-lg bg-paper-surface shadow-paper-shadow"
  data-clock-widget
>
  <h2 class="flex items-center gap-3 m-0 mb-[22px] text-paper-ink text-[0.95rem] [&_svg]:w-[22px] [&_svg]:h-[22px] [&_svg]:text-paper-accent">
    <Icon name="clock" /> Local Time
  </h2>
  <div class="flex items-center min-w-0">
    <time
      class="flex items-baseline min-w-0 text-paper-ink font-meta text-[clamp(2.2rem,4vw,3.2rem)] font-[650] leading-none tracking-normal"
      data-time
    >
      <span data-time-main>--:--</span><small class="text-[0.48em] font-[650] leading-none" data-time-seconds>:--</small>
    </time>
  </div>
  <p class="mt-3 mb-0 text-paper-ink-soft text-[0.86rem]" data-date>----</p>
</article>

<script>
  const widget = document.querySelector('[data-clock-widget]');
  const timeMainNode = widget?.querySelector('[data-time-main]');
  const secondsNode = widget?.querySelector('[data-time-seconds]');
  const dateNode = widget?.querySelector('[data-date]');
  const weekdays = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];

  function updateClock() {
    const now = new Date();
    const hours = String(now.getHours()).padStart(2, '0');
    const minutes = String(now.getMinutes()).padStart(2, '0');
    const seconds = String(now.getSeconds()).padStart(2, '0');
    const date = `${now.getFullYear()}/${now.getMonth() + 1}/${now.getDate()} ${weekdays[now.getDay()]}`;

    if (timeMainNode) timeMainNode.textContent = `${hours}:${minutes}`;
    if (secondsNode) secondsNode.textContent = `:${seconds}`;
    if (dateNode) dateNode.textContent = date;
  }

  updateClock();
  window.setInterval(updateClock, 1000);
</script>
