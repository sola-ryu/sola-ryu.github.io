---
import { getCollection } from 'astro:content';
import Icon from '../Icon.astro';
import {
  createRecentBlogHeatmap,
  type HeatmapDay,
  type HeatmapPost,
} from '../../utils/blog-heatmap';

interface Props {
  weeks?: number;
  showLatest?: boolean;
  latestCount?: number;
  excludeDraft?: boolean;
  dateArchiveBaseHref?: string;
  startDate?: Date | string | null;
}

const {
  weeks = 24,
  showLatest = true,
  latestCount = 1,
  excludeDraft = true,
  dateArchiveBaseHref,
  startDate,
} = Astro.props;
const posts = await getCollection('blog', ({ data }) => !excludeDraft || !data.draft);
const heatmap = createRecentBlogHeatmap(posts, weeks, latestCount, startDate);
const heatmapLabel = startDate
  ? `Writing activity since ${heatmap.startDate}`
  : `Recent ${heatmap.weeks} weeks writing activity`;
const formatDate = new Intl.DateTimeFormat('en', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
});

function getPostLabel(count: number) {
  return `${count} ${count === 1 ? 'post' : 'posts'}`;
}

function getDayTitle(day: HeatmapDay) {
  if (day.isFuture) return `${day.date}: upcoming`;

  const titleLines = day.posts.slice(0, 5).map((post) => `- ${post.title}`);
  const overflowLine = day.posts.length > 5 ? ['...'] : [];

  return [`${day.date}: ${getPostLabel(day.count)}`, ...titleLines, ...overflowLine].join('\n');
}

function getDayHref(day: HeatmapDay) {
  if (dateArchiveBaseHref && day.count > 0) {
    return `${dateArchiveBaseHref.replace(/\/$/, '')}/${day.date}/`;
  }

  return day.posts[0]?.href;
}

function getTooltipPosts(posts: HeatmapPost[]) {
  return posts.slice(0, 5);
}
---

<article class="grid gap-4 p-5 border-transparent bg-transparent shadow-none overflow-visible hover:border-transparent hover:shadow-none">
  <div class="grid grid-cols-3 gap-2">
    <div class="grid gap-0.5 min-w-0">
      <strong class="text-paper-ink text-xl leading-none">{heatmap.totalPosts}</strong>
      <span class="overflow-hidden text-paper-ink-soft text-[0.72rem] leading-[1.2] truncate">Total posts</span>
    </div>
    <div class="grid gap-0.5 min-w-0">
      <strong class="text-paper-ink text-xl leading-none">{heatmap.activeDays}</strong>
      <span class="overflow-hidden text-paper-ink-soft text-[0.72rem] leading-[1.2] truncate">Active days</span>
    </div>
    <div class="grid gap-0.5 min-w-0">
      <strong class="text-paper-ink text-xl leading-none">{heatmap.currentStreak}</strong>
      <span class="overflow-hidden text-paper-ink-soft text-[0.72rem] leading-[1.2] truncate">Day streak</span>
    </div>
  </div>

  {
    showLatest && heatmap.latestPosts.length > 0 && (
      <aside class="grid gap-1.5 p-2.5 border border-paper-line rounded-md bg-paper-surface-muted" aria-label="Latest published posts">
        <strong class="text-paper-accent text-[0.7rem] leading-[1.15]">Latest</strong>
        <div class="grid gap-1">
          {heatmap.latestPosts.map((post) => (
            <a class="latest-link grid grid-cols-[minmax(0,1fr)_max-content_24px] items-center min-w-0 gap-2 text-inherit no-underline hover:rounded-md focus-visible:rounded-md focus-visible:outline-2 focus-visible:outline-[color-mix(in_srgb,var(--paper-accent)_28%,transparent)] focus-visible:outline-offset-3" href={post.href} aria-label={`Open latest post: ${post.title}`}>
              <em class="overflow-hidden text-paper-ink text-sm font-semibold leading-[1.2] truncate">{post.title}</em>
              <time class="text-paper-ink-soft text-[0.68rem] leading-none whitespace-nowrap">{formatDate.format(post.date)}</time>
              <span class="latest-icon grid place-items-center w-6 h-6 rounded-lg text-paper-accent transition-all duration-180 hover:bg-paper-control-hover hover:-translate-y-0.5" aria-hidden="true">
                <Icon name="external" size={15} />
              </span>
            </a>
          ))}
        </div>
      </aside>
    )
  }

  <div class="rhythm-grid grid grid-cols-[24px_minmax(0,1fr)] gap-2 items-center w-full max-w-full overflow-visible" aria-label={heatmapLabel}>
    <div class="weekday-column grid grid-rows-3 gap-1 text-paper-ink-faint text-[0.62rem] leading-none" aria-hidden="true">
      <span>Mon</span>
      <span>Wed</span>
      <span>Fri</span>
    </div>

    <div class="heatmap-cells grid grid-flow-col grid-rows-[repeat(7,8px)] auto-cols-[8px] gap-0.625 w-[calc((8px_*_var(--week-count))_+_(_2.5px_*_(var(--week-count)_-_1)))] max-w-full" style={`--week-count: ${heatmap.weeks};`}>
      {
        heatmap.days.map((day) => {
          if (day.isFuture) {
            return <span class="heatmap-cell future-cell w-2 h-2 min-w-2 min-h-2 bg-transparent shadow-none" aria-hidden="true" />;
          }

          const href = getDayHref(day);
          const content = (
            <span
              class={`heatmap-cell level-${day.level} block w-2 h-2 min-w-2 min-h-2 rounded-[2.5px] bg-[rgba(102,125,109,0.12)] shadow-[inset_0_0_0_1px_var(--paper-line)]`}
              title={getDayTitle(day)}
              aria-hidden="true"
            />
          );
          const tooltip = (
            <span class="tooltip absolute left-1/2 -bottom-[calc(100%+_9px)] z-4 grid w-max max-w-[230px] gap-1.5 p-2.5 border border-paper-line rounded-md bg-paper-surface shadow-paper-shadow-lift text-paper-ink text-[0.78rem] leading-[1.35] opacity-0 pointer-events-none translate-x-[-50%] translate-y-1.5 transition-all duration-140">
              <strong class="text-paper-ink text-base">{formatDate.format(new Date(day.date))}</strong>
              <span>{getPostLabel(day.count)}</span>
              {day.posts.length > 0 && (
                <ul class="grid gap-0.5 mt-1 pl-4">
                  {getTooltipPosts(day.posts).map((post) => (
                    <li class="break-all">{post.title}</li>
                  ))}
                  {day.posts.length > 5 && <li>...</li>}
                </ul>
              )}
            </span>
          );

          return href ? (
            <a class="cell-link relative text-inherit no-underline hover:z-10 hover:.heatmap-cell:outline-1 hover:.heatmap-cell:outline-paper-line-strong hover:.heatmap-cell:outline-offset-1 focus-visible:z-10" href={href} aria-label={getDayTitle(day)}>
              {content}
              {tooltip}
            </a>
          ) : (
            <span class="cell-link static-cell relative text-inherit no-underline hover:z-10 hover:.heatmap-cell:outline-1 hover:.heatmap-cell:outline-paper-line-strong hover:.heatmap-cell:outline-offset-1 focus-visible:z-10" aria-label={getDayTitle(day)}>
              {content}
              {tooltip}
            </span>
          );
        })
      }
    </div>
  </div>

  <footer class="flex items-center gap-1.5 text-paper-ink-faint text-[0.72rem]">
    <span>Less</span>
    {[0, 1, 2, 3, 4].map((level) => <i class={`heatmap-cell level-${level} w-[9px] h-[9px]`} />)}
    <span>More</span>
  </footer>
</article>

<style>
  .rhythm-grid {
    --cell-size: 8px;
    --cell-gap: 2.5px;
  }

  .heatmap-cells {
    width: calc(
      (var(--cell-size) * var(--week-count)) + (var(--cell-gap) * (var(--week-count) - 1))
    );
  }

  .heatmap-cell,
  .cell-link {
    width: var(--cell-size);
    height: var(--cell-size);
    min-width: 8px;
    min-height: 8px;
  }

  .level-0 { background: rgba(102, 125, 109, 0.16); }
  .level-1 { background: #dce8dc; }
  .level-2 { background: #b9cbb9; }
  .level-3 { background: #8fa58f; }
  .level-4 { background: #667d6d; }

  .cell-link:hover .tooltip,
  .cell-link:focus-visible .tooltip {
    opacity: 1;
    transform: translate(-50%, 0);
  }

  .cell-link:nth-child(n + 19) .tooltip {
    left: auto;
    right: 0;
    transform: translate(0, 6px);
  }

  .cell-link:nth-child(n + 19):hover .tooltip,
  .cell-link:nth-child(n + 19):focus-visible .tooltip {
    transform: translate(0, 0);
  }

  @media (max-width: 1180px) and (min-width: 821px) {
    .rhythm-grid {
      --cell-size: 8px;
    }
  }

  @media (max-width: 820px) {
    .heatmap-card {
      gap: 14px;
      padding: 0;
      overflow: hidden;
    }

    .rhythm-grid {
      --cell-gap: 2.5px;
      grid-template-columns: 22px minmax(0, 1fr);
      overflow: hidden;
      width: 100%;
    }

    .heatmap-cells {
      grid-template-rows: repeat(7, auto);
      grid-auto-columns: minmax(0, 1fr);
      width: 100%;
      max-width: 360px;
    }

    .heatmap-cells .heatmap-cell,
    .heatmap-cells .cell-link {
      width: 100%;
      height: auto;
      min-width: 0;
      min-height: 0;
      aspect-ratio: 1;
    }

    .weekday-column {
      font-size: 0.58rem;
    }
  }
</style>
