---
import Icon from '../Icon.astro';

interface DoingItem {
  text: string;
  mark: string;
}

const { items } = Astro.props as { items: DoingItem[] };
---

<article class="pt-6">
  <h2 class="flex items-center gap-[10px] m-0 mb-4 text-paper-ink text-[1.06rem] [&_svg]:w-[21px] [&_svg]:h-[21px] [&_svg]:text-paper-accent">
    <Icon name="calendar" /> Recently
  </h2>
  <ul class="grid m-0 p-0 list-none">
    {
      items.map((item) => (
        <li class="relative grid grid-cols-[minmax(0,1fr)_32px] gap-3 items-center py-[14px] pl-[18px] border-t border-paper-line text-paper-ink text-[0.98rem] before:content-[''] before:absolute before:left-0 before:w-[5px] before:h-[5px] before:rounded-full before:bg-paper-accent">
          <span>{item.text}</span>
          <strong class="text-[0.82rem] text-right">{item.mark}</strong>
        </li>
      ))
    }
  </ul>
</article>
