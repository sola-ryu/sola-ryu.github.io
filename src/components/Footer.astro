---
import Icon from './Icon.astro';

const today = new Date();
---

<footer>
  &copy; {today.getFullYear()} navfolio. Released as an open-source starter.
  <div class="social-links">
    <a href="https://example.com/" target="_blank">
      <span class="sr-only">Open example website</span>
      <Icon name="mastodon" size={18} />
    </a>
    <a href="https://twitter.com/example" target="_blank">
      <span class="sr-only">Open example Twitter profile</span>
      <Icon name="twitter" size={18} />
    </a>
    <a href="https://github.com/example" target="_blank">
      <span class="sr-only">Open example GitHub profile</span>
      <Icon name="github" size={18} />
    </a>
  </div>
</footer>
<style>
  footer {
    padding: 3em 1em 6em;
    color: var(--paper-ink-faint);
    font-size: 0.88rem;
    text-align: center;
  }
  .social-links {
    display: flex;
    justify-content: center;
    gap: 1em;
    margin-top: 1em;
  }
  .social-links a {
    display: inline-grid;
    place-items: center;
    width: 40px;
    height: 40px;
    text-decoration: none;
    color: var(--paper-ink-soft);
  }
  .social-links a:hover {
    color: var(--paper-accent);
  }
</style>
