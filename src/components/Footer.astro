---
import Icon from './Icon.astro';
import { getSiteConfig } from '../data/site';

const today = new Date();
const { profile, site } = await getSiteConfig();
---

<footer class="px-4 pt-12 pb-24 text-paper-ink-faint text-[0.88rem] text-center">
  &copy; {today.getFullYear()}
  {site.title}. {site.footerNote}
  <div class="flex justify-center gap-4 mt-4">
    <a href={profile.website} target="_blank" rel="noreferrer" class="inline-grid place-items-center w-10 h-10 text-paper-ink-soft no-underline hover:text-paper-accent">
      <span class="sr-only">Open website</span>
      <Icon name="compass" size={18} />
    </a>
    <a href={profile.github} target="_blank" rel="noreferrer" class="inline-grid place-items-center w-10 h-10 text-paper-ink-soft no-underline hover:text-paper-accent">
      <span class="sr-only">Open GitHub profile</span>
      <Icon name="github" size={18} />
    </a>
    <a href={`mailto:${profile.email}`} class="inline-grid place-items-center w-10 h-10 text-paper-ink-soft no-underline hover:text-paper-accent">
      <span class="sr-only">Email</span>
      <Icon name="mail" size={18} />
    </a>
  </div>
</footer>
