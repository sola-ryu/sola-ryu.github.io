---
interface Props {
  currentPage: 'home' | 'blog' | 'dreams' | 'about';
}

const { currentPage } = Astro.props;

// Moon phase calculation
const now = new Date();
const year = now.getFullYear();
const month = now.getMonth() + 1;
const day = now.getDate();

// Simple moon phase algorithm (synodic month ≈ 29.53 days)
const knownNewMoon = new Date(2000, 5, 5).getTime(); // Jan 6, 2000
const synodicMonth = 29.53058867;
const age = (now.getTime() - knownNewMoon) / (1000 * 60 * 60 * 24);
const phase = ((age % synodicMonth) + synodicMonth) % synodicMonth;

// Map phase to moon emoji
const moonPhases = [
  '🌑', // new moon
  '🌒', // waxing crescent
  '🌓', // first quarter
  '🌔', // waxing gibbous
  '🌕', // full moon
  '🌖', // waning gibbous
  '🌗', // last quarter
  '🌘', // waning crescent
];
const phaseIndex = Math.round((phase / synodicMonth) * 7.999) % 8;

function linkClass(page: string): string {
  const base = [
    'relative text-[0.75rem] tracking-[0.1em] lowercase no-underline py-0.5',
    'text-text-dim hover:text-text-muted transition-colors duration-200',
    'after:content-[""] after:absolute after:bottom-0 after:left-0 after:w-0 after:h-px',
    'after:bg-accent after:transition-all after:duration-300',
    'after:shadow-[0_0_4px_rgba(167,139,250,0.4)] hover:after:w-full',
    'sm:text-[0.65rem]',
    'dreams:text-silver dreams:hover:text-white',
  ].join(' ');
  if (currentPage === page) {
    return `${base} !text-silver after:!w-full`;
  }
  return base;
}
---

<nav
  class="post:bg-gradient-to-b pointer-events-none fixed inset-x-0 top-0 z-50 flex items-center justify-between from-[rgba(8,8,13,0.95)] from-60% to-transparent px-8 py-5 transition-opacity duration-300 sm:px-5 sm:py-4"
>
  <a
    href="/"
    class="text-text-dim hover:text-text-muted dreams:text-silver dreams:hover:text-white pointer-events-auto flex items-center gap-[0.4rem] no-underline transition-colors duration-200 sm:text-[0.75rem]"
    aria-label="Home"
  >
    <span
      class="text-[0.9rem] leading-none opacity-70 saturate-[0.8] filter transition-[opacity,filter] duration-200 select-none hover:opacity-100 hover:saturate-[1.2]"
      >{moonPhases[phaseIndex]}</span
    >
    <img
      src="/avatar.png"
      alt="sola"
      class="h-7 w-7 rounded-full border border-[rgba(167,139,250,0.2)] object-cover transition-all duration-200 hover:border-[rgba(167,139,250,0.5)] hover:shadow-[0_0_8px_rgba(167,139,250,0.3)]"
    />
    <span class="text-[0.85rem] font-normal tracking-[0.08em] lowercase">sola</span>
  </a>
  <div class="pointer-events-auto flex items-center gap-8 sm:gap-5">
    <a
      href="/"
      class:list={[linkClass('home'), currentPage === 'home' ? '!text-silver after:!w-full' : '']}
      >home</a
    >
    <a
      href="/blog/"
      class:list={[linkClass('blog'), currentPage === 'blog' ? '!text-silver after:!w-full' : '']}
      >blog</a
    >
    <a
      href="/dreams/"
      class:list={[
        linkClass('dreams'),
        currentPage === 'dreams' ? '!text-silver after:!w-full' : '',
      ]}>dreams</a
    >
    <a
      href="/about/"
      class:list={[linkClass('about'), currentPage === 'about' ? '!text-silver after:!w-full' : '']}
      >about</a
    >
  </div>
</nav>
