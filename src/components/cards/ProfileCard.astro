---
import Icon from '../Icon.astro';

interface Profile {
  name: string;
  handle: string;
  role: string;
  company: string;
  location: string;
  email: string;
  website: string;
  meta: string;
  avatar: string;
}

const { profile } = Astro.props as { profile: Profile };
---

<article class="grid justify-items-end min-h-[420px] w-full py-5 text-right overflow-hidden max-[820px]:justify-items-center max-[820px]:min-h-0 max-[820px]:pt-1 max-[820px]:pb-0">
  <div class="relative w-44 h-44 mb-[18px] ml-auto rounded-full max-[820px]:mx-auto">
    <img
      src={profile.avatar}
      alt={`${profile.name} GitHub avatar`}
      width="176"
      height="176"
      loading="eager"
      class="w-full h-full object-cover rounded-[inherit]"
    />
  </div>

  <div class="max-[820px]:text-center">
    <h1 class="m-0 text-paper-ink text-[1.42rem] tracking-normal">{profile.name}</h1>
    <p class="mt-1 mb-[14px] text-paper-ink-soft text-[0.94rem]">{profile.handle}</p>
    <span class="inline-flex items-center gap-2 justify-end text-paper-ink text-[0.82rem] max-[820px]:justify-center [&_svg]:w-5 [&_svg]:h-5 [&_svg]:shrink-0 [&_svg]:text-paper-accent">
      <Icon name="sparkle" />
      {profile.role}
    </span>
  </div>
</article>
