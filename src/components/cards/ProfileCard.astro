---
import Icon from '../Icon.astro';

interface Profile {
  name: string;
  handle: string;
  role: string;
  company: string;
  location: string;
  email: string;
  website: string;
  meta: string;
  avatar: string;
}

const { profile } = Astro.props as { profile: Profile };
---

<article class="glass-card profile-card">
  <div class="avatar-wrap">
    <img
      src={profile.avatar}
      alt={`${profile.name} GitHub avatar`}
      width="176"
      height="176"
      loading="eager"
    />
    <span class="status-dot" aria-hidden="true"></span>
  </div>

  <div class="profile-heading">
    <h1>{profile.name}</h1>
    <p>{profile.handle}</p>
    <span><Icon name="sparkle" /> {profile.role}</span>
  </div>
</article>

<style>
  .profile-card {
    min-height: 420px;
    padding: 34px 26px;
    text-align: center;
    overflow: hidden;
  }

  .avatar-wrap {
    position: relative;
    width: 176px;
    height: 176px;
    margin: 0 auto 22px;
    padding: 12px;
    border-radius: 50%;
    background: var(--paper-surface-muted);
    box-shadow: inset 0 0 0 1px var(--paper-line), var(--paper-shadow);
  }

  .avatar-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: inherit;
  }

  .status-dot {
    position: absolute;
    right: 22px;
    bottom: 22px;
    width: 24px;
    height: 24px;
    border: 5px solid var(--paper-surface);
    border-radius: 50%;
    background: #8f714b;
    box-shadow: none;
  }

  .profile-heading h1 {
    margin: 0;
    color: var(--paper-ink);
    font-size: 2.2rem;
    letter-spacing: 0;
  }

  .profile-heading p {
    margin: 4px 0 14px;
    color: var(--paper-ink-soft);
    font-size: 1.1rem;
  }

  .profile-heading span {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    border: 1px solid var(--paper-line);
    border-radius: 999px;
    background: var(--paper-control);
    box-shadow: var(--paper-shadow);
    color: var(--paper-ink);
    font-size: 0.96rem;
  }

  .profile-heading svg {
    width: 20px;
    height: 20px;
    flex: 0 0 auto;
    color: var(--paper-accent);
  }

  @media (max-width: 820px) {
    .profile-card {
      min-height: auto;
    }
  }
</style>
