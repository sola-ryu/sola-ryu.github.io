---
interface Intro {
  title: string;
  name: string;
  body: string[];
}

interface Quote {
  text: string[];
}

const { intro, quote } = Astro.props as { intro: Intro; quote?: Quote };
---

<article class="flex flex-col min-h-[280px] p-0 border-transparent bg-transparent shadow-none hover:border-transparent hover:shadow-none hover:transform-none">
  <div class="relative z-1 flex w-full max-w-none flex-col items-start">
    {
      quote && (
        <div class="mb-2 text-[rgba(102,125,109,0.32)] font-display text-3xl leading-[0.7]" aria-hidden="true">
          "
        </div>
      )
    }
    <h2 class="m-0 mb-4.5 text-paper-ink max-w-none text-2xl md:text-3.35rem md:leading-[1.04] whitespace-nowrap">
      <span class="mr-3 text-paper-accent font-normal" aria-hidden="true">Hi,</span>
      {intro.title}<em class="text-paper-accent italic"> {intro.name}</em>
    </h2>
    {
      quote && (
        <blockquote class="block max-w-[52ch] m-0 mb-6.5 p-0 border-0 text-paper-ink-soft font-note text-sm md:text-base italic leading-[1.72] text-right">
          <span class="block">- {quote.text.slice(0, 2).join(' ')}</span>
          <span class="block">{quote.text.slice(2).join(' ')}</span>
        </blockquote>
      )
    }
    {intro.body.map((paragraph) => <p class="w-full m-0 mb-3 text-paper-ink max-w-[66ch] text-base md:text-[1.02rem] leading-[1.92]">{paragraph}</p>)}
  </div>
</article>
