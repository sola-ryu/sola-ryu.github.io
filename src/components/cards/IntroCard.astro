---
interface Intro {
  title: string;
  name: string;
  body: string[];
}

interface Quote {
  text: string[];
}

const { intro, quote } = Astro.props as { intro: Intro; quote?: Quote };
---

<article class="glass-card intro-card">
  <div class="intro-copy">
    {
      quote && (
        <div class="quote-mark" aria-hidden="true">
          "
        </div>
      )
    }
    <h2>
      <span aria-hidden="true">Hi,</span>
      {intro.title.replace(intro.name, '')}<em>{intro.name}</em>
    </h2>
    {
      quote && (
        <blockquote>
          {quote.text.map((line) => (
            <span>{line}</span>
          ))}
        </blockquote>
      )
    }
    {intro.body.map((paragraph) => <p>{paragraph}</p>)}
  </div>
</article>

<style>
  .intro-card {
    display: flex;
    flex-direction: column;
    min-height: 330px;
    padding: 38px;
  }

  .intro-copy {
    position: relative;
    z-index: 1;
    display: flex;
    width: 100%;
    max-width: none;
    flex-direction: column;
    align-items: flex-start;
  }

  .quote-mark {
    margin-bottom: -4px;
    color: rgba(123, 84, 55, 0.42);
    font-family: var(--font-display);
    font-size: 4.8rem;
    line-height: 0.7;
  }

  h2 {
    margin: 0 0 20px;
    color: var(--paper-ink);
    font-size: clamp(2rem, 3.1vw, 3rem);
    line-height: 1.1;
  }

  h2 span {
    margin-right: 0.35rem;
    color: var(--paper-accent);
    font-style: normal;
  }

  h2 em {
    color: var(--paper-accent);
    font-style: italic;
  }

  blockquote {
    display: block;
    margin: 0 0 28px;
    padding: 0;
    border: 0;
    color: #4a3a2b;
    font-family: var(--font-note);
    font-size: clamp(1.05rem, 1.4vw, 1.36rem);
    font-style: italic;
    line-height: 1.55;
  }

  blockquote span {
    display: block;
  }

  p {
    width: 100%;
    margin: 0 0 16px;
    color: var(--paper-ink);
    font-size: 0.98rem;
    line-height: 1.9;
  }

  p:last-child {
    margin-bottom: 0;
  }

  @media (max-width: 640px) {
    .intro-card {
      padding: 28px;
    }

    h2 {
      font-size: 1.7rem;
    }
  }
</style>
