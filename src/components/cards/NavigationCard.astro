---
import Icon from '../Icon.astro';

interface NavItem {
  icon: string;
  title: string;
  subtitle: string;
  href: string;
}

const { items } = Astro.props as { items: NavItem[] };
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');

function withBase(href: string) {
  if (href.startsWith('http') || href.startsWith('mailto:') || href.startsWith('#')) {
    return href;
  }

  if (href === '/') {
    return `${basePath}/` || '/';
  }

  return `${basePath}${href.startsWith('/') ? href : `/${href}`}`;
}
---

<article class="w-full py-5 max-[820px]:p-0">
  <nav aria-label="identity websites" class="grid w-full gap-2 max-[820px]:grid-cols-2 max-[820px]:gap-1">
    {
      items.map((item) => (
        <a
          class="grid grid-cols-[28px_minmax(0,1fr)_18px] gap-3 items-center py-2 text-paper-ink no-underline transition-colors duration-[180ms] ease hover:text-paper-accent max-[820px]:grid-cols-[24px_minmax(0,1fr)] max-[820px]:gap-[10px] max-[820px]:py-[9px]"
          href={withBase(item.href)}
        >
          <span class="text-paper-accent [&_svg]:w-5 [&_svg]:h-5 max-[820px]:grid max-[820px]:place-items-center">
            <Icon name={item.icon} />
          </span>
          <span>
            <strong class="block overflow-hidden text-ellipsis whitespace-nowrap text-[0.96rem] font-[650]">{item.title}</strong>
            <small class="block mt-0.5 text-paper-ink-soft text-[0.82rem] overflow-hidden text-ellipsis whitespace-nowrap max-[820px]:hidden">{item.subtitle}</small>
          </span>
          <span class="text-paper-accent [&_svg]:w-[18px] [&_svg]:h-[18px] max-[820px]:hidden">
            <Icon name="external" />
          </span>
        </a>
      ))
    }
  </nav>
</article>
