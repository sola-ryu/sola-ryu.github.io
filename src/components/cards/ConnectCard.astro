---
import Icon from '../Icon.astro';

interface ConnectItem {
  label: string;
  href: string;
  icon: string;
}

const { items } = Astro.props as { items: ConnectItem[] };
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');

function withBase(href: string) {
  if (href.startsWith('http') || href.startsWith('mailto:') || href.startsWith('#')) {
    return href;
  }

  if (href === '/') {
    return `${basePath}/` || '/';
  }

  return `${basePath}${href.startsWith('/') ? href : `/${href}`}`;
}
---

<article class="p-4.5 border border-paper-line rounded-lg bg-paper-control text-paper-ink shadow-paper-shadow hover:bg-paper-control-hover hover:text-paper-accent hover:transform-none transition-transform duration-180 ease-in-out">
  <h2 class="flex items-center gap-2.5 m-0 mb-3.5 text-paper-ink text-base">
    <Icon name="link" />
    Connect
  </h2>
  <div class="grid grid-cols-5 gap-3">
    {
      items.map((item) => (
        <a href={withBase(item.href)} aria-label={item.label} class="inline-flex items-center justify-center gap-2 min-h-[48px] p-3 border border-paper-line rounded-lg bg-paper-control text-paper-ink no-underline shadow-paper-shadow hover:bg-paper-control-hover hover:text-paper-accent transition-transform duration-180 ease-in-out">
          <Icon name={item.icon} />
          <span>{item.label}</span>
        </a>
      ))
    }
  </div>
</article>
