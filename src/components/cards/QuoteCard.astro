---
interface Quote {
  text: string[];
  image: string;
}

const { quote } = Astro.props as { quote: Quote };
---

<article class="grid grid-cols-[48px_minmax(0,1fr)_minmax(210px,0.84fr)] gap-3.5 items-center min-h-[250px] p-5.5 overflow-hidden">
  <div class="align-self-start text-paper-accent font-heading text-5xl leading-[0.9]" aria-hidden="true">"</div>
  <blockquote class="grid gap-2.25 m-0 border-0 p-0 text-paper-ink font-article text-xl italic leading-[1.3]">
    {quote.text.map((line) => <span>{line}</span>)}
  </blockquote>
  <img
    src={quote.image}
    alt="desk workspace illustration"
    width="410"
    height="230"
    loading="eager"
    class="w-full h-[206px] object-cover object-center rounded-lg filter saturate-94"
  />
</article>
