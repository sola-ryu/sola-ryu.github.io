---
import { getSiteConfig } from '../../data/site';
import { canRenderProvider, getCommentProvider } from '../../utils/comments';
import GiscusComment from './GiscusComment.astro';
import UtterancesComment from './UtterancesComment.astro';
import WalineComment from './WalineComment.astro';

interface Props {
  frontmatter: {
    comments?: boolean;
  };
  pathname: string;
}

const { frontmatter, pathname } = Astro.props;
const { comments } = await getSiteConfig();
const provider = frontmatter.comments === false ? null : getCommentProvider(comments);
const shouldRender = provider ? canRenderProvider(comments, provider) : false;
---

{
  shouldRender && provider && (
    <section
      class="comment-section w-[min(100%,720px)] mt-[42px] pt-7 border-t border-paper-line"
      aria-label="Comments"
      data-comment-path={pathname}
    >
      <div class="grid gap-1 mb-[18px] text-paper-ink-faint font-meta text-[0.82rem] leading-[1.5]">
        <p class="m-0 text-paper-ink text-[0.9rem] font-bold">Comments</p>
        <span class="block">Quiet notes for this article.</span>
      </div>

      {provider === 'giscus' && <GiscusComment config={comments.giscus} />}
      {provider === 'utterances' && <UtterancesComment config={comments.utterances} />}
      {provider === 'waline' && <WalineComment config={comments.waline} />}
    </section>
  )
}
