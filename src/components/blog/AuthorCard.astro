---
import { Github, Mail, Rss } from 'lucide-astro';
import { getSiteConfig } from '../../data/site';

const { profile } = await getSiteConfig();
---

<aside class="grid justify-items-center gap-[10px] p-[26px_20px] text-center border border-paper-line rounded-lg bg-paper-surface shadow-paper-shadow">
  <img
    src={profile.avatar}
    alt={`${profile.name} avatar`}
    class="w-[82px] h-[82px] border-[6px] border-paper-surface-muted rounded-lg shadow-paper-shadow object-cover"
  />
  <h2 class="mt-1 mb-0 text-paper-ink text-[1.25rem] leading-[1.1]">{profile.name}</h2>
  <p class="m-0 text-paper-ink-soft text-[0.9rem]">{profile.handle}</p>
  <span class="inline-flex px-[11px] py-1.5 border border-paper-line rounded-lg bg-paper-control text-paper-accent text-[0.78rem] font-bold">{profile.role}</span>

  <div class="flex gap-[9px] mt-1" aria-label="Author links">
    <a href={profile.github} aria-label="GitHub" class="inline-grid place-items-center w-[34px] h-[34px] border border-paper-line rounded-lg bg-paper-control text-paper-ink hover:text-paper-accent hover:bg-paper-control-hover">
      <Github size={16} />
    </a>
    <a href={`mailto:${profile.email}`} aria-label="Email" class="inline-grid place-items-center w-[34px] h-[34px] border border-paper-line rounded-lg bg-paper-control text-paper-ink hover:text-paper-accent hover:bg-paper-control-hover">
      <Mail size={16} />
    </a>
    <a href="/rss.xml" aria-label="RSS" class="inline-grid place-items-center w-[34px] h-[34px] border border-paper-line rounded-lg bg-paper-control text-paper-ink hover:text-paper-accent hover:bg-paper-control-hover">
      <Rss size={16} />
    </a>
  </div>
</aside>
