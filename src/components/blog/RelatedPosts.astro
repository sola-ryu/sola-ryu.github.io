---
import type { CollectionEntry } from 'astro:content';
import FormattedDate from '../FormattedDate.astro';
import SmartImage from '../SmartImage.astro';

interface Props {
  posts: CollectionEntry<'blog'>[];
  class?: string;
}

const { posts, class: className } = Astro.props;
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');

function withBase(href: string) {
  if (href === '/') {
    return `${basePath}/` || '/';
  }

  return `${basePath}${href.startsWith('/') ? href : `/${href}`}`;
}
---

<aside class:list={['border border-paper-line rounded-lg bg-paper-surface shadow-paper-shadow p-[18px]', className]}>
  <h2 class="m-0 mb-[14px] text-paper-ink text-[0.9rem] leading-[1.2] uppercase">More from navfolio</h2>
  <div class="related-list grid gap-3">
    {
      posts.map((post) => (
        <a
          class:list={[
            'grid gap-[5px] items-center text-paper-ink no-underline hover:[&_strong]:text-paper-accent',
            { 'grid-cols-[58px_minmax(0,1fr)] !gap-[10px]': Boolean(post.data.heroImage) },
          ]}
          href={withBase(`/blog/${post.id}/`)}
        >
          {post.data.heroImage && (
            <SmartImage
              width={88}
              height={64}
              src={post.data.heroImage}
              alt=""
              class="block w-[58px] h-12 rounded-md bg-paper-surface-muted object-cover shadow-paper-shadow [filter:saturate(0.7)]"
            />
          )}
          <span class="grid gap-1 min-w-0">
            <strong class="line-clamp-2 text-[0.86rem] leading-[1.25]">{post.data.title}</strong>
            <small class="text-paper-ink-faint text-[0.75rem]">
              <FormattedDate date={post.data.date} />
            </small>
          </span>
        </a>
      ))
    }
  </div>
</aside>
