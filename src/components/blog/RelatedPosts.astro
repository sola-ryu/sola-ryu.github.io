---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import FormattedDate from '../FormattedDate.astro';

interface Props {
  posts: CollectionEntry<'blog'>[];
}

const { posts } = Astro.props;
---

<aside class="related-posts blog-card">
  <h2>More from navfolio</h2>
  <div class="related-list">
    {
      posts.map((post) => (
        <a href={`/blog/${post.id}/`}>
          {post.data.heroImage && <Image width={88} height={64} src={post.data.heroImage} alt="" />}
          <span>
            <strong>{post.data.title}</strong>
            <small>
              <FormattedDate date={post.data.pubDate} />
            </small>
          </span>
        </a>
      ))
    }
  </div>
</aside>

<style>
  .related-posts {
    padding: 18px;
  }

  h2 {
    margin: 0 0 14px;
    color: var(--paper-ink);
    font-size: 0.9rem;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .related-list {
    display: grid;
    gap: 12px;
  }

  a {
    display: grid;
    grid-template-columns: 1fr;
    gap: 5px;
    align-items: center;
    color: var(--paper-ink);
    text-decoration: none;
  }

  a:hover strong {
    color: var(--paper-accent);
  }

  img {
    display: none;
    width: 58px;
    height: 48px;
    border-radius: 6px;
    object-fit: cover;
    box-shadow: var(--paper-shadow);
    filter: saturate(0.7);
  }

  span {
    display: grid;
    gap: 4px;
    min-width: 0;
  }

  strong {
    display: -webkit-box;
    overflow: hidden;
    font-size: 0.86rem;
    line-height: 1.25;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  small {
    color: var(--paper-ink-faint);
    font-size: 0.75rem;
  }
</style>
