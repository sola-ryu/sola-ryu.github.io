---
import type { CollectionEntry } from 'astro:content';
import FormattedDate from '../FormattedDate.astro';
import SmartImage from '../SmartImage.astro';

type BlogPost = CollectionEntry<'blog'>;

interface PaginationState {
  currentPage: number;
  lastPage: number;
  total: number;
  size: number;
  url: {
    current: string;
    prev?: string;
    next?: string;
  };
}

interface Props {
  page: PaginationState & {
    data: BlogPost[];
  };
  postOffset?: number;
}

const { page, postOffset = 0 } = Astro.props;
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
const hasPagination = page.lastPage > 1;

function withBase(href: string) {
  if (href === '/') {
    return `${basePath}/` || '/';
  }
  return `${basePath}${href.startsWith('/') ? href : `/${href}`}`;
}

function getPageHref(pageNumber: number) {
  return pageNumber === 1 ? '/blog/' : `/blog/page/${pageNumber}/`;
}
---

<header class="archive-hero archive-header-shared page-header-spacing">
  <div class="archive-header-main">
    <p class="archive-kicker">Notebook archive</p>
    <h1 class="archive-title">Writing notes</h1>
  </div>
  <p class="archive-note">
    Loose pages, technical margins, and small notes gathered into a readable stack.
  </p>
</header>

<section>
  <ul class="post-stack">
    {page.data.map((post, index) => (
      <li class="post-item relative">
        <a
          class:list={['post-link relative grid grid-cols-[minmax(0,1fr)_210px] gap-7.5 items-center min-h-33 p-6.5 overflow-visible border-t border-paper-line bg-transparent text-paper-ink no-underline hover:border-paper-line hover:-translate-y-0.5 transition-transform duration-180 ease-in-out', { 'without-thumb': !post.data.heroImage }]}
          href={withBase(`/blog/${post.id}/`)}
        >
          <div class="post-copy relative z-1 grid content-between gap-0">
            <div>
              <span class="post-index text-paper-ink-faint font-meta text-[0.76rem] tracking-wider">{String(postOffset + index + 1).padStart(2, '0')}</span>
              <h2 class="title m-0 text-paper-ink text-xl md:text-[1.72rem] leading-[1.24]">{post.data.title}</h2>
              <p class="date flex flex-wrap gap-0 items-center mt-2.5 text-paper-ink-soft font-meta text-sm font-semibold">
                <FormattedDate date={post.data.date} />
                {post.data.tags.length > 0 && (
                  <span class="post-tags inline-flex flex-wrap items-center gap-0">
                    {post.data.tags.map((tag) => (
                      <span class="post-tag text-paper-accent">#{tag}</span>
                    ))}
                  </span>
                )}
              </p>
            </div>
            <p class="post-excerpt m-0 text-paper-ink-soft text-[0.98rem] leading-[1.78]">{post.data.description}</p>
          </div>
          {post.data.heroImage && (
            <span class="thumb-wrap relative z-1 self-center w-[210px] aspect-[4/3] overflow-hidden border border-paper-line rounded-md bg-paper-surface-muted saturate-[0.86] contrast-[0.98] clip-[polygon(0_0,100%_0,100%_100%,18px_100%,0_calc(100%_-_18px))]">
              <SmartImage width={520} height={360} src={post.data.heroImage} alt="" class="block w-full h-full object-cover opacity-[0.92]" />
            </span>
          )}
        </a>
      </li>
    ))}
  </ul>
</section>

{hasPagination && (
  <nav class="archive-pagination grid grid-cols-[minmax(98px,_auto)_minmax(0,1fr)_minmax(98px,_auto)] gap-4 items-center mt-8.5 pt-5 border-t border-paper-line font-meta text-sm" aria-label="Blog pagination">
    <a
      class:list={['pagination-link inline-flex items-center justify-center min-h-9 px-3.5 border border-paper-line rounded-md bg-paper-control text-paper-ink-soft no-underline transition-all duration-180 hover:border-paper-line-strong hover:bg-paper-control-hover hover:text-paper-ink hover:-translate-y-0.5', { disabled: !page.url.prev }]}
      href={page.url.prev ? withBase(page.url.prev) : undefined}
      aria-disabled={!page.url.prev}
    >
      Previous
    </a>
    <div class="pagination-pages flex flex-wrap gap-2 justify-center" aria-label={`Page ${page.currentPage} of ${page.lastPage}`}>
      {Array.from({ length: page.lastPage }, (_, index) => {
        const pageNumber = index + 1;
        const isCurrent = pageNumber === page.currentPage;
        return (
          <a
            class:list={['pagination-number inline-flex items-center justify-center min-h-9 min-w-9 px-2.5 border border-paper-line rounded-md bg-paper-control text-paper-ink-soft no-underline transition-all duration-180 hover:border-paper-line-strong hover:bg-paper-control-hover hover:text-paper-ink hover:-translate-y-0.5', { current: isCurrent }]}
            href={withBase(getPageHref(pageNumber))}
            aria-current={isCurrent ? 'page' : undefined}
          >
            {pageNumber}
          </a>
        );
      })}
    </div>
    <a
      class:list={['pagination-link inline-flex items-center justify-center min-h-9 px-3.5 border border-paper-line rounded-md bg-paper-control text-paper-ink-soft no-underline transition-all duration-180 hover:border-paper-line-strong hover:bg-paper-control-hover hover:text-paper-ink hover:-translate-y-0.5', { disabled: !page.url.next }]}
      href={page.url.next ? withBase(page.url.next) : undefined}
      aria-disabled={!page.url.next}
    >
      Next
    </a>
  </nav>
)}

<style>
  .post-stack { display: grid; gap: 0; padding: 0; list-style: none; }
  .post-link.without-thumb,
  .post-item:first-child .post-link.without-thumb { grid-template-columns: minmax(0, 1fr); min-height: auto; }
  .post-index { color: var(--paper-ink-faint); font-family: var(--font-meta); font-size: 0.76rem; letter-spacing: 0.1em; }
  .title { margin: 0; color: var(--paper-ink); font-size: clamp(1.28rem, 2vw, 1.72rem); line-height: 1.24; }
  .post-link.without-thumb .title { max-width: none; }
  .date { display: flex; flex-wrap: wrap; gap: 0; align-items: center; margin: 2.5px 0 0; color: var(--paper-ink-soft); font-family: var(--font-meta); font-size: 0.86rem; font-weight: 600; }
  .post-tags { display: inline-flex; flex-wrap: wrap; align-items: center; gap: 0; }
  .post-tags::before { margin: 0 2.25px; color: var(--paper-ink-faint); content: '\00b7'; }
  .post-tag { color: var(--paper-accent); font-family: var(--font-serif-cn); font-weight: 700; }
  .post-tag + .post-tag::before { margin: 0 1.5px; color: var(--paper-ink-faint); content: '\00b7'; }
  .post-excerpt { margin: 0; color: var(--paper-ink-soft); font-size: 0.98rem; line-height: 1.78; }
  .thumb-wrap { position: relative; z-index: 1; align-self: center; width: 210px; aspect-ratio: 4/3; overflow: hidden; border: 1px solid var(--paper-line); border-radius: 6px; background: var(--paper-surface-muted); filter: saturate(0.86) contrast(0.98); clip-path: polygon(0 0, 100% 0, 100% 100%, 18px 100%, 0 calc(100% - 18px)); }
  .thumb-wrap img { display: block; width: 100%; height: 100%; object-fit: cover; border-radius: 0; mix-blend-mode: normal; opacity: 0.92; }
  :root[data-theme='dark'] .thumb-wrap { background: transparent; filter: none; }
  :root[data-theme='dark'] .thumb-wrap img { opacity: 1; mix-blend-mode: normal; }
  .post-item:first-child .post-link { grid-template-columns: minmax(0, 1fr) 210px; min-height: 33px; padding: 6.5px 0; }
  .post-item:first-child .title { font-size: clamp(1.36rem, 2.2vw, 1.9rem); }
  .pagination-number.current { border-color: var(--paper-line-strong); background: var(--paper-surface); color: var(--paper-accent); }
  .pagination-link.disabled { pointer-events: none; opacity: 0.45; }

  @media (max-width: 720px) {
    .post-link, .post-item:first-child .post-link { grid-template-columns: 1fr; gap: 4.5px; padding: 5.5px 0; }
    .thumb-wrap { width: 100%; aspect-ratio: 16/9; order: -1; clip-path: polygon(0 0, 100% 0, 100% 100%, 20px 100%, 0 calc(100% - 20px)); }
    .title, .post-item:first-child .title { font-size: 1.45rem; line-height: 1.22; }
    .archive-pagination { grid-template-columns: 1fr; gap: 3px; margin-top: 7px; }
    .pagination-link, .pagination-pages { width: 100%; }
  }
</style>
