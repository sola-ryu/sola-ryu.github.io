---
import { Heart, Link2, Share2, ThumbsDown } from 'lucide-astro';
---

<div
  class="sticky bottom-6 z-[2] flex items-center justify-center gap-2 w-fit max-w-full mx-auto mt-7 py-[10px] pr-3 pl-[18px] border border-paper-line rounded-lg bg-paper-nav shadow-paper-shadow-lift max-[520px]:w-full max-[520px]:justify-between max-[520px]:bottom-[14px] max-[520px]:pl-[14px]"
  aria-label="Article feedback actions"
>
  <span class="mr-1 text-paper-ink-soft text-[0.86rem] font-bold whitespace-nowrap max-[520px]:text-[0.8rem]">
    Was this helpful?
  </span>
  <button
    type="button"
    aria-label="Like article"
    class="inline-grid place-items-center w-[38px] h-[38px] p-0 border border-paper-line rounded-lg bg-paper-control text-paper-ink cursor-pointer hover:bg-paper-control-hover hover:text-paper-accent max-[520px]:w-[34px] max-[520px]:h-[34px]"
  >
    <Heart size={17} />
  </button>
  <button
    type="button"
    aria-label="Dislike article"
    class="inline-grid place-items-center w-[38px] h-[38px] p-0 border border-paper-line rounded-lg bg-paper-control text-paper-ink cursor-pointer hover:bg-paper-control-hover hover:text-paper-accent max-[520px]:w-[34px] max-[520px]:h-[34px]"
  >
    <ThumbsDown size={17} />
  </button>
  <button
    type="button"
    aria-label="Share article"
    class="inline-grid place-items-center w-[38px] h-[38px] p-0 border border-paper-line rounded-lg bg-paper-control text-paper-ink cursor-pointer hover:bg-paper-control-hover hover:text-paper-accent max-[520px]:w-[34px] max-[520px]:h-[34px]"
  >
    <Share2 size={17} />
  </button>
  <button
    type="button"
    aria-label="Copy article link"
    class="inline-grid place-items-center w-[38px] h-[38px] p-0 border border-paper-line rounded-lg bg-paper-control text-paper-ink cursor-pointer hover:bg-paper-control-hover hover:text-paper-accent max-[520px]:w-[34px] max-[520px]:h-[34px]"
  >
    <Link2 size={17} />
  </button>
</div>
