---
import FormattedDate from '../FormattedDate.astro';

interface Props {
  date: Date;
  readingTime: string;
  tags: string[];
}

const { date, readingTime, tags } = Astro.props;
---

<aside class="p-[22px] border border-paper-line rounded-lg bg-paper-surface shadow-paper-shadow">
  <dl class="grid gap-[14px] m-0">
    <div class="grid gap-[3px]">
      <dt class="text-paper-ink-faint font-ui text-[0.75rem] font-bold uppercase">Reading time</dt>
      <dd class="m-0 text-paper-ink font-meta text-[0.92rem] font-bold">{readingTime}</dd>
    </div>
    <div class="grid gap-[3px]">
      <dt class="text-paper-ink-faint font-ui text-[0.75rem] font-bold uppercase">Created</dt>
      <dd class="m-0 text-paper-ink font-meta text-[0.92rem] font-bold"><FormattedDate date={date} /></dd>
    </div>
  </dl>

  <div class="flex flex-wrap gap-2 mt-[18px]" aria-label="Article tags">
    {tags.map((tag) => <span class="px-[10px] py-1.5 border border-paper-line rounded-lg bg-paper-control text-paper-accent font-meta text-[0.76rem] font-bold">{tag}</span>)}
  </div>
</aside>
