---
import { getSiteConfig } from '../data/site';
import HeaderLink from './HeaderLink.astro';
import Icon from './Icon.astro';

const { profile, site, topNav } = await getSiteConfig();
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');

function withBase(href: string) {
  if (href === '/') {
    return `${basePath}/` || '/';
  }

  return `${basePath}${href.startsWith('/') ? href : `/${href}`}`;
}
---

<header class="m-0 p-4 bg-paper-nav border-b border-paper-line shadow-[0_1px_2px_rgba(0,0,0,0.02)]">
  <nav class="flex items-center justify-between">
    <h2 class="m-0 text-base"><a href={withBase('/')} class="no-underline">{site.title}</a></h2>
    <div class="internal-links">
      {topNav.links.map((link) => <HeaderLink href={link.href}>{link.label}</HeaderLink>)}
    </div>
    <div class="social-links flex">
      <a href={profile.website} target="_blank" rel="noreferrer" class="flex items-center justify-center w-[44px] h-[44px] p-0">
        <span class="sr-only">Open website</span>
        <Icon name="compass" size={18} />
      </a>
      <a href={profile.github} target="_blank" rel="noreferrer" class="flex items-center justify-center w-[44px] h-[44px] p-0">
        <span class="sr-only">Open GitHub profile</span>
        <Icon name="github" size={18} />
      </a>
      <a href={`mailto:${profile.email}`} class="flex items-center justify-center w-[44px] h-[44px] p-0">
        <span class="sr-only">Email</span>
        <Icon name="mail" size={18} />
      </a>
    </div>
  </nav>
</header>

<style>
  nav a {
    padding: 1em 0.5em;
    color: var(--paper-ink);
    border-bottom: 2px solid transparent;
    text-decoration: none;
  }
  nav a.active {
    text-decoration: none;
    border-bottom-color: var(--paper-accent);
  }
  @media (max-width: 720px) {
    .social-links {
      display: none;
    }
  }
</style>
