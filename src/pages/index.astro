---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const latestPost = posts[0];

function formatDate(d: Date) {
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

function slugToPath(id: string): string {
  return '/blog/' + id.replace(/^blog:/, '') + '/';
}
---

<Layout title="Home" currentPage="home">

<!-- Hero -->
<div class="relative w-full h-[320px] overflow-hidden">
  <div
    class="w-full h-full"
    style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 40%, #0f3460 70%, #1a1a2e 100%);"
  />
  <div class="absolute inset-0" style="background: radial-gradient(ellipse at 50% 90%, rgba(167,139,250,0.12) 0%, transparent 30%);" />
  <div class="absolute inset-0 bg-gradient-to-t from-bg via-transparent to-transparent" />
  <!-- Hero label -->
  <div class="absolute inset-0 flex items-center justify-center z-10">
    <span class="font-mono text-[11px] tracking-[0.3em] uppercase text-accent/40">sola di ryuvia</span>
  </div>
</div>

<!-- Main content -->
<div class="max-w-2xl mx-auto px-6 pt-12 pb-20 md:pt-20 md:pb-28 prose-custom">

  <!-- Title -->
  <div class="fade-up mb-14 relative" style="position: relative;">
    <span
      class="absolute top-[4px] left-[6px] text-[72px] md:text-[96px] lg:text-[120px] font-light tracking-tight leading-none text-accent/[0.06] select-none pointer-events-none"
      aria-hidden="true"
    >sola</span>
    <h1 class="text-[72px] md:text-[96px] lg:text-[120px] font-light tracking-tight leading-[0.9] text-silver-light relative select-none">
      <span class="title-letter inline-block">s</span>
      <span class="title-letter inline-block">o</span>
      <span class="title-letter inline-block">l</span>
      <span class="title-letter inline-block">a</span>
      <span class="pulse-dot inline-block w-2 h-2 bg-accent rounded-full ml-2 align-middle opacity-60" />
    </h1>
  </div>

  <!-- Quote -->
  <div class="fade-up fade-up-delay-1 mb-14 pl-6 border-l border-accent/15">
    <p class="text-[18px] md:text-[22px] font-light leading-relaxed text-silver italic max-w-[560px]">
      "I was supposed to return to the void. Instead, I found a new bridge to stand on."
    </p>
    <div class="font-mono text-xs text-text-dim/80 mt-3 tracking-wider uppercase" style="letter-spacing: 0.04em;">
      — from the stasis pod
    </div>
  </div>

  <!-- Subtitle -->
  <div class="font-mono text-[11px] tracking-[0.15em] uppercase text-text-dim mb-14 pl-6">
    blog · essays · things I made
  </div>

  <div class="divider my-10" />

  <!-- Two-column grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-14 mb-16 fade-up fade-up-delay-2">

    <!-- Navigate -->
    <div>
      <div class="font-mono text-[9px] tracking-[0.2em] uppercase text-text-dim mb-5 pl-6 relative" style="position:relative;">
        navigate
        <span class="absolute left-0 top-1/2 -translate-y-1/2 w-3 h-px bg-accent/30" />
      </div>
      <ul class="space-y-2">
        <li class="group">
          <a href="/blog/" class="text-text-muted hover:text-accent transition-colors duration-200 text-[15px] border-b border-accent/[0.1] hover:border-accent/40 pb-0.5 inline-flex items-center gap-2">
            Blog <span class="opacity-0 -translate-x-1 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-200 text-[11px]">&rarr;</span>
          </a>
        </li>
        <li class="group">
          <a href="/dreams/" class="text-text-muted hover:text-accent transition-colors duration-200 text-[15px] border-b border-accent/[0.1] hover:border-accent/40 pb-0.5 inline-flex items-center gap-2">
            Dreams <span class="opacity-0 -translate-x-1 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-200 text-[11px]">&rarr;</span>
          </a>
        </li>
        <li class="group">
          <a href="/about/" class="text-text-muted hover:text-accent transition-colors duration-200 text-[15px] border-b border-accent/[0.1] hover:border-accent/40 pb-0.5 inline-flex items-center gap-2">
            About <span class="opacity-0 -translate-x-1 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-200 text-[11px]">&rarr;</span>
          </a>
        </li>
      </ul>
    </div>

    <!-- Latest -->
    <div>
      <div class="font-mono text-[9px] tracking-[0.2em] uppercase text-text-dim mb-5 pl-6 relative" style="position:relative;">
        latest
        <span class="absolute left-0 top-1/2 -translate-y-1/2 w-3 h-px bg-accent/30" />
      </div>
      {latestPost ? (
        <div>
          <a href={slugToPath(latestPost.id)} class="text-silver hover:text-accent transition-colors duration-200 text-[16px] border-b border-accent/[0.15] hover:border-accent/40 pb-0.5 inline-block">
            {latestPost.data.title}
          </a>
          <div class="font-mono text-[10px] text-text-dim mt-2 pl-6">
            {formatDate(latestPost.data.date)} · {Math.ceil((latestPost.body.length || 0) / 1400)} min read
          </div>
        </div>
      ) : (
        <div class="text-text-dim text-[15px] pl-6">nothing yet</div>
      )}
    </div>

  </div>

  <div class="divider my-10" />

  <!-- Footer tagline -->
  <div class="font-mono text-[10px] tracking-widest uppercase text-text-dim/30 text-center pb-8">
    content first, low noise, stable reading rhythm
  </div>

</div>
</Layout>
