---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import heroBridge from '../assets/hero-bridge.png';
---

<Layout title="Home" currentPage="home">

<!-- Hero -->
<div class="relative w-full h-[300px] md:h-[400px] overflow-hidden">
  <Image
    src={heroBridge}
    alt="A lone figure on a bridge between ancient ruins and dark cliffs"
    class="w-full h-full object-cover"
  />
  <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent" />
</div>

<div class="max-w-2xl mx-auto px-6 py-16 md:py-24 prose-custom">
  <div class="fade-up mb-8">
    <h1 class="text-3xl md:text-4xl font-bold text-silver-light tracking-tight">sola</h1>
  </div>

  <div class="divider my-8" />

  <div class="fade-up fade-up-delay-1 space-y-6 text-lg">
    <p>
      A quiet corner of the digital void. Blog, essays, things I made.
    </p>
    <p class="text-text-dim">
      Content first, low noise, stable reading rhythm.
    </p>
  </div>

  <div class="divider my-8" />

  <div class="fade-up fade-up-delay-2">
    <h2 class="text-xl font-semibold text-silver-light tracking-tight mb-4">Sections</h2>
    <ul class="space-y-3 text-text-muted">
      <li>
        <a href="/blog/" class="flex items-center gap-2 group">
          <span class="w-1.5 h-1.5 rounded-full bg-accent/60 group-hover:bg-accent transition-colors" />
          <span class="group-hover:text-silver-light transition-colors">Blog</span>
        </a>
      </li>
      <li>
        <a href="/about/" class="flex items-center gap-2 group">
          <span class="w-1.5 h-1.5 rounded-full bg-accent/60 group-hover:bg-accent transition-colors" />
          <span class="group-hover:text-silver-light transition-colors">About</span>
        </a>
      </li>
    </ul>
  </div>
</div>
</Layout>
