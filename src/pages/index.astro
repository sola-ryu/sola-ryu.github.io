---
import ConnectCard from '../components/cards/ConnectCard.astro';
import GithubStatsCard from '../components/cards/GithubStatsCard.astro';
import IntroCard from '../components/cards/IntroCard.astro';
import NavigationCard from '../components/cards/NavigationCard.astro';
import ProfileCard from '../components/cards/ProfileCard.astro';
import QuoteCard from '../components/cards/QuoteCard.astro';
import DashboardGrid from '../components/layout/DashboardGrid.astro';
import BlogHeatmap from '../components/widgets/BlogHeatmap.astro';
import ClockWidget from '../components/widgets/ClockWidget.astro';
import DoingCard from '../components/widgets/DoingCard.astro';
import {
  connectLinks,
  doingItems,
  githubStats,
  intro,
  navigationLinks,
  profile,
  quote,
} from '../data/profile';
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = 'navfolio | Personal Dashboard';
const pageDescription = 'A customizable personal navigation portfolio dashboard built with Astro.';
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <div class="dashboard-bg" aria-hidden="true"></div>
  <DashboardGrid>
    <Fragment slot="left">
      <ProfileCard profile={profile} />
      <NavigationCard items={navigationLinks} />
    </Fragment>

    <Fragment slot="center">
      <QuoteCard quote={quote} />
      <IntroCard intro={intro} />
      <GithubStatsCard stats={githubStats} />
      <ConnectCard items={connectLinks} />
    </Fragment>

    <Fragment slot="right">
      <ClockWidget />
      <BlogHeatmap weeks={24} />
      <DoingCard items={doingItems} />
    </Fragment>
  </DashboardGrid>
</BaseLayout>
