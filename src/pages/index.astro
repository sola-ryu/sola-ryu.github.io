---
import IntroCard from '../components/cards/IntroCard.astro';
import NavigationCard from '../components/cards/NavigationCard.astro';
import ProfileCard from '../components/cards/ProfileCard.astro';
import DashboardFlow from '../components/layout/DashboardFlow.astro';
import BlogHeatmap from '../components/widgets/BlogHeatmap.astro';
import DoingCard from '../components/widgets/DoingCard.astro';
import { doingItems, intro, navigationLinks, profile, quote } from '../data/profile';
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = 'navfolio | Digital Publication Space';
const pageDescription = 'A calm AI-native personal publication space for notes, links, and writing.';
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <div class="publication-bg" aria-hidden="true"></div>
  <DashboardFlow>
    <Fragment slot="profile">
      <ProfileCard profile={profile} />
    </Fragment>

    <Fragment slot="hero">
      <IntroCard intro={intro} quote={quote} />
    </Fragment>

    <Fragment slot="activity">
      <BlogHeatmap weeks={24} />
    </Fragment>

    <Fragment slot="links">
      <NavigationCard items={navigationLinks} />
    </Fragment>

    <Fragment slot="recently">
      <DoingCard items={doingItems} />
    </Fragment>
  </DashboardFlow>
</BaseLayout>
