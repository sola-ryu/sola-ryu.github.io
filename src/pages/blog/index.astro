---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

function idToSlug(id: string): string {
  return id.replace(/^blog:/, '');
}
---

<Layout title="Blog" currentPage="blog">
  <div class="prose-custom mx-auto max-w-2xl px-6 pt-28 pb-16 md:pt-36 md:pb-24">
    <div class="fade-up mb-8">
      <h1 class="text-silver-light text-3xl font-bold tracking-tight md:text-4xl">blog</h1>
    </div>

    <div class="divider my-8"></div>

    <div class="space-y-8">
      {
        posts.map((post, i) => (
          <a
            href={`/blog/${idToSlug(post.id)}/`}
            class="post-card fade-up group relative block overflow-hidden rounded-lg"
            style={{ animationDelay: `${i * 0.05}s` }}
          >
            {post.data.coverImage && (
              <div class="relative h-[180px] w-full overflow-hidden">
                <Image
                  src={post.data.coverImage}
                  alt=""
                  width={800}
                  height={400}
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent" />
              </div>
            )}
            <div class="px-1 py-3">
              <time class="text-text-dim text-sm">{formatDate(post.data.date)}</time>
              <h2 class="text-silver-light mt-1 mb-2 text-xl font-semibold">{post.data.title}</h2>
              <p class="text-text-muted leading-relaxed">{post.data.description}</p>
              {post.data.tags.length > 0 && (
                <div class="mt-3 flex gap-2">
                  {post.data.tags.map((tag) => (
                    <span class="tag-pill">{tag}</span>
                  ))}
                </div>
              )}
            </div>
          </a>
        ))
      }
    </div>

    {
      posts.length === 0 && (
        <p class="text-text-dim italic">No posts yet. Something will appear eventually.</p>
      )
    }
  </div>
</Layout>
