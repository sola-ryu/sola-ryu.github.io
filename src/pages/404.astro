---
import BaseLayout from '../layouts/BaseLayout.astro';

const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');

function withBase(href: string) {
  if (href === '/') {
    return `${basePath}/` || '/';
  }

  return `${basePath}${href.startsWith('/') ? href : `/${href}`}`;
}
---

<BaseLayout title="404 Not Found" description="这页暂时没有找到，可能已经迁移或还没有写下。">
  <div class="publication-bg" aria-hidden="true"></div>
  <main
    class="grid min-h-[calc(100vh-56px)] place-items-center pt-[116px] pb-[72px] max-[720px]:min-h-screen max-[720px]:pt-[92px] max-[720px]:pb-[42px]"
    aria-labelledby="not-found-title"
  >
    <section class="w-[min(100%,860px)] px-[clamp(6px,3vw,18px)] py-[clamp(22px,5vw,56px)] animate-not-found-in max-[720px]:py-6 max-[720px]:px-0">
      <p class="m-0 mb-3 text-paper-accent font-ui text-[0.78rem] font-bold tracking-[0.12em] uppercase leading-[1.2]">
        404 Not Found
      </p>
      <h1
        id="not-found-title"
        class="max-w-[11em] m-0 text-paper-ink text-[clamp(2.3rem,7vw,4.6rem)] leading-[1.08] max-[720px]:max-w-[8em] max-[720px]:text-[2.34rem]"
      >
        这页还没有落在纸上
      </h1>
      <p class="max-w-[42rem] mt-6 mb-0 text-paper-ink-soft text-[1.04rem] leading-[1.86] max-[720px]:mt-[18px] max-[720px]:text-[0.98rem]">
        也许链接换了位置，也许这只是一次走岔的小路。先回到熟悉的入口，继续慢慢翻。
      </p>
      <nav
        class="flex flex-wrap gap-[10px] mt-[30px] max-[720px]:grid max-[720px]:grid-cols-1 max-[720px]:mt-6"
        aria-label="404 page links"
      >
        <a
          class="primary-link inline-flex items-center justify-center min-h-[42px] px-[14px] py-2 border border-[color-mix(in_srgb,var(--paper-accent)_24%,var(--paper-line))] rounded-lg bg-paper-control text-paper-ink font-ui text-[0.88rem] font-bold leading-[1.2] no-underline transition-[transform,border-color,background,color] duration-[180ms] ease hover:border-paper-line-strong hover:bg-paper-control-hover hover:text-paper-accent hover:-translate-y-px focus-visible:border-paper-line-strong focus-visible:bg-paper-control-hover focus-visible:text-paper-accent focus-visible:-translate-y-px focus-visible:[outline:2px_solid_var(--paper-accent)] focus-visible:[outline-offset:3px]"
          href={withBase('/')}
        >
          回到首页
        </a>
        <a
          class="inline-flex items-center justify-center min-h-[42px] px-[14px] py-2 border border-paper-line rounded-lg bg-paper-control text-paper-ink font-ui text-[0.88rem] font-bold leading-[1.2] no-underline transition-[transform,border-color,background,color] duration-[180ms] ease hover:border-paper-line-strong hover:bg-paper-control-hover hover:text-paper-accent hover:-translate-y-px focus-visible:border-paper-line-strong focus-visible:bg-paper-control-hover focus-visible:text-paper-accent focus-visible:-translate-y-px focus-visible:[outline:2px_solid_var(--paper-accent)] focus-visible:[outline-offset:3px]"
          href={withBase('/blog')}
        >
          去博客
        </a>
      </nav>
    </section>
  </main>
</BaseLayout>
