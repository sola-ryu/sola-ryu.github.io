---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import bgImage from '../../assets/dreams-bg.png';

const dreams = (await getCollection('dreams'))
  .filter((d) => !d.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Layout title="Dreams" currentPage="dreams">
  <Image
    src={bgImage}
    alt=""
    class="fixed inset-0 z-0 h-full w-full object-cover"
    style={{ pointerEvents: 'none' }}
  />
  <div
    class="fixed inset-0 z-0 h-full w-full bg-linear-(--dreams-overlay) bg-size-[110rem] bg-center"
  >
  </div>
  <div class="relative z-10 mx-auto max-w-2xl px-6 pt-32 pb-20 md:pt-40 md:pb-28">
    <div class="fade-up mb-12">
      <h1
        class="text-silver-light text-3xl font-light tracking-tight md:text-4xl"
        style="font-weight: 300;"
      >
        dreams
      </h1>
      <p class="text-text-silver mt-3 text-sm font-light italic">things I remember from sleeping</p>
    </div>

    <div class="space-y-0">
      {
        dreams.map((dream, i) => (
          <a
            href={`/dreams/${dream.id.replace(/^dreams:/, '')}/`}
            key={dream.id}
            class="fade-up group border-border/30 relative block border-b py-5 transition-opacity first:border-t hover:opacity-85"
            style={{ animationDelay: `${i * 0.08}s` }}
          >
            <time class="font-mono text-xs tracking-wide">{formatDate(dream.data.date)}</time>
          </a>
        ))
      }
    </div>

    {dreams.length === 0 && <p class="text-text-dim/60 mt-8 text-sm italic">still dreaming</p>}
  </div>
</Layout>
