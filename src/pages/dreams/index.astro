---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import bgImage from '../../assets/dreams-bg.png';

const dreams = (await getCollection('dreams'))
  .filter(d => !d.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Layout title="Dreams" currentPage="dreams">
<Image
  src={bgImage}
  alt=""
  class="fixed inset-0 h-full w-full z-0 object-cover"
  style={{ pointerEvents: 'none' }}
/>
<div class="fixed inset-0 h-full w-full z-0 bg-linear-(--dreams-overlay) bg-center bg-size-[110rem]"></div>
<div class="max-w-2xl mx-auto px-6 pt-32 pb-20 md:pt-40 md:pb-28 relative z-10">
  <div class="fade-up mb-12">
    <h1 class="text-3xl md:text-4xl font-light text-silver-light tracking-tight" style="font-weight: 300;">dreams</h1>
    <p class="text-sm text-text-silver mt-3 font-light italic">things I remember from sleeping</p>
  </div>

  <div class="space-y-0">
    {dreams.map((dream, i) => (
      <a href={`/dreams/${dream.id.replace(/^dreams:/, '')}/`} key={dream.id} class="block fade-up relative group py-5 border-b border-border/30 hover:opacity-85 transition-opacity first:border-t" style={{ animationDelay: `${i * 0.08}s` }}>
        <time class="text-xs font-mono tracking-wide">{formatDate(dream.data.date)}</time>
      </a>
    ))}
  </div>

  {dreams.length === 0 && (
    <p class="text-text-dim/60 italic text-sm mt-8">still dreaming</p>
  )}
</div>
</Layout>
