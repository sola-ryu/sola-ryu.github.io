---
import Layout from '../../layouts/Layout.astro';
import { getCollection, getAllCollections, render } from 'astro:content';
import { Image } from 'astro:assets';
import bgImage from '../../assets/dreams-bg.png';

export async function getStaticPaths() {
  const dreams = (await getCollection('dreams')).filter((d) => !d.data.draft);
  return dreams.map((dream) => ({
    params: { slug: dream.id.replace(/^dreams:/, '') },
    props: { dream },
  }));
}

interface Props {
  params: Promise<{ slug: string }>;
}

const { slug } = await Astro.params;
const dream = (await getCollection('dreams')).find((d) => d.id.replace(/^dreams:/, '') === slug);

if (!dream) {
  return Astro.redirect('/dreams/');
}

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const rendered = await render(dream);
const contentHtml = rendered.Content;
---

<Layout
  title={`${dream.data.date.toLocaleString('en-US', { month: 'long', day: 'numeric' })} — dreams`}
  currentPage="dreams"
>
  <Image
    src={bgImage}
    alt=""
    class="fixed inset-0 z-0 h-full w-full object-cover"
    style={{ pointerEvents: 'none' }}
  />
  <div
    class="fixed inset-0 z-0 h-full w-full bg-linear-(--dreams-overlay) bg-size-[110rem] bg-center"
  >
  </div>
  <div class="prose-custom mx-auto max-w-2xl px-6 pt-32 pb-20 md:pt-40 md:pb-28">
    <div class="fade-up mb-16">
      <time class="text-text font-mono text-xs tracking-wide">{formatDate(dream.data.date)}</time>
      <h1
        class="text-silver-light mt-4 mb-0 text-3xl font-light md:text-4xl"
        style="font-weight: 300; line-height: 1.3;"
      >
        {dream.data.date.toLocaleString('en-US', { month: 'long', day: 'numeric' })}
      </h1>
    </div>

    <div class="divider my-8"></div>

    <div
      class="fade-up prose-custom dream-content leading-[1.85] font-light"
      style={{ animationDelay: '0.15s' }}
    >
      <rendered.Content />
    </div>

    <div class="border-border/40 mt-20 border-t pt-8">
      <a
        href="/dreams/"
        class="text-text-dim hover:text-accent font-mono text-xs tracking-wide transition-colors duration-200"
        >&larr; all dreams</a
      >
    </div>
  </div>

  <style is:global>
    .dream-content p {
      margin-bottom: 1.5em;
      color: var(--color-text);
      white-space: pre-wrap;
    }
    .dream-content p:last-child {
      margin-bottom: 0;
    }
    .dream-content blockquote {
      border-left-color: rgba(167, 139, 250, 0.3);
      font-style: italic;
    }
    .dream-content img {
      opacity: 0.85;
    }
  </style>
</Layout>
