---
import Layout from '../../layouts/Layout.astro';
import { getCollection, getAllCollections, render } from 'astro:content';

export async function getStaticPaths() {
  const dreams = (await getCollection('dreams')).filter(d => !d.data.draft);
  return dreams.map(dream => ({
    params: { slug: dream.id.replace(/^dreams:/, '') },
    props: { dream },
  }));
}

interface Props {
  params: Promise<{ slug: string }>;
}

const { slug } = await Astro.params;
const dream = (await getCollection('dreams'))
  .find(d => d.id.replace(/^dreams:/, '') === slug);

if (!dream) {
  return Astro.redirect('/dreams/');
}

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const rendered = await render(dream);
const contentHtml = rendered.Content;
---

<Layout title={`${dream.data.date.toLocaleString('en-US', { month: 'long', day: 'numeric' })} — dreams`} currentPage="dreams">
<div class="max-w-2xl mx-auto px-6 pt-32 pb-20 md:pt-40 md:pb-28 prose-custom">
  <div class="fade-up mb-16">
    <time class="text-xs text-text-dim font-mono tracking-wide">{formatDate(dream.data.date)}</time>
    <h1 class="text-3xl md:text-4xl font-light text-silver-light mt-4 mb-0" style="font-weight: 300; line-height: 1.3;">{dream.data.date.toLocaleString('en-US', { month: 'long', day: 'numeric' })}</h1>
  </div>

  <div class="divider my-8" />

  <div class="fade-up prose-custom font-light leading-[1.85] dream-content" style={{ animationDelay: '0.15s' }}>
    <rendered.Content />
  </div>

  <div class="mt-20 pt-8 border-t border-border/40">
    <a href="/dreams/" class="text-xs text-text-dim hover:text-accent transition-colors duration-200 font-mono tracking-wide">&larr; all dreams</a>
  </div>
</div>

<style>
  .dream-content p {
    margin-bottom: 1.5em;
    color: var(--color-text);
  }
  .dream-content p:last-child {
    margin-bottom: 0;
  }
  .dream-content blockquote {
    border-left-color: rgba(167, 139, 250, 0.3);
    font-style: italic;
  }
  .dream-content img {
    opacity: 0.85;
  }
</style>
</Layout>
