---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Sola di Ryuvia</title>
    <meta name="description" content="A quiet corner of the digital void." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-full bg-bg text-text antialiased selection:bg-accent/20">
    <!-- Ambient glow — barely there, like memory -->
    <div class="ambient-glow fixed top-[-200px] left-1/2 -translate-x-1/2 w-[1200px] h-[800px] bg-[radial-gradient(ellipse_at_center,rgba(167,139,250,0.03)_0%,transparent_55%)] pointer-events-none z-0" />
    <!-- Noise texture — static between signals -->
    <div class="noise-overlay fixed inset-0 opacity-[0.012] pointer-events-none z-1" style='background-image:url("data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noise%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.85%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noise)%22/%3E%3C/svg%3E")' />

    <div class="relative z-20">
      <slot />
    </div>
  </body>
</html>
