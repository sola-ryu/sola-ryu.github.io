---
import { type CollectionEntry, getCollection } from 'astro:content';
import ArticleHeader from '../components/article/ArticleHeader.astro';
import BlogTopNav from '../components/blog/BlogTopNav.astro';
import BottomActionBar from '../components/blog/BottomActionBar.astro';
import RelatedPosts from '../components/blog/RelatedPosts.astro';
import SubscribeCard from '../components/blog/SubscribeCard.astro';
import TableOfContents from '../components/blog/TableOfContents.astro';
import BaseHead from '../components/BaseHead.astro';

interface Props {
  post?: CollectionEntry<'blog'>;
  headings?: { depth: number; slug: string; text: string }[];
  title?: string;
  description?: string;
  pubDate?: Date;
  updatedDate?: Date;
  heroImage?: ImageMetadata;
  tags?: string[];
}

const props = Astro.props;
const headings = props.headings ?? [];
const post = props.post ?? {
  id: 'standalone',
  body: props.description ?? '',
  data: {
    title: props.title ?? 'Untitled',
    description: props.description ?? '',
    pubDate: props.pubDate ?? new Date(),
    updatedDate: props.updatedDate,
    heroImage: props.heroImage,
    tags: props.tags ?? [],
    draft: false,
  },
};
const { title, description, pubDate, heroImage } = post.data;
const bodyText = 'body' in post && typeof post.body === 'string' ? post.body : description;
const words = bodyText.trim().match(/\S+/g) ?? [];
const wordCount = words.length;
const readingTime = `${Math.max(1, Math.ceil(wordCount / 220))} min read`;
const tags = post.data.tags ?? [];
const renderedTocItems = headings
  .filter((heading) => heading.depth === 2 || heading.depth === 3)
  .map((heading) => ({ href: `#${heading.slug}`, label: heading.text }));
const tocItems = renderedTocItems;
const hasToc = tocItems.length > 0;

const relatedPosts = (await getCollection('blog', ({ id, data }) => id !== post.id && !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body class="blog-detail-page">
    <BlogTopNav />
    <div class="blog-background" aria-hidden="true"></div>

    <main class="blog-layout">
      <div class="article-column">
        <article class="article-card">
          <ArticleHeader
            title={title}
            pubDate={pubDate}
            wordCount={wordCount}
            readingTime={readingTime}
            tags={tags}
            heroImage={heroImage}
          />

          <section id="article-start" class="article-content">
            <slot />
          </section>
        </article>

        <BottomActionBar />

        <section class="mobile-after-article" aria-label="More article tools">
          {hasToc && <TableOfContents items={tocItems} compact />}
          <RelatedPosts posts={relatedPosts} />
          <SubscribeCard />
        </section>
      </div>

      <aside class="right-sidebar" aria-label="Reading tools">
        <div class="right-sidebar-inner">
          {hasToc && <TableOfContents items={tocItems} />}
          <RelatedPosts posts={relatedPosts} />
          <SubscribeCard />
        </div>
      </aside>
    </main>
  </body>
</html>

<style>
  :global(html) {
    background: var(--paper-bg);
    scroll-behavior: smooth;
  }

  :global(.blog-detail-page) {
    min-height: 100vh;
    overflow-x: hidden;
    background: var(--paper-detail-bg);
    color: var(--paper-ink);
  }

  .blog-background {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .blog-background::before {
    position: absolute;
    inset: 0;
    background-image: linear-gradient(var(--paper-rule) 1px, transparent 1px);
    background-size: 100% 34px;
    content: '';
    opacity: 0.2;
  }

  .blog-layout {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 780px) 252px;
    gap: 48px;
    width: min(100%, var(--layout-shell-width));
    max-width: none;
    margin: 0 auto;
    padding: var(--layout-page-top) var(--layout-page-gutter) var(--layout-page-bottom);
  }

  .article-column {
    min-width: 0;
  }

  .right-sidebar-inner,
  .mobile-after-article {
    display: grid;
    gap: 18px;
    align-content: start;
  }

  .right-sidebar-inner {
    position: sticky;
    top: 96px;
    align-self: start;
  }

  :global(.blog-card) {
    border: 1px solid var(--paper-line);
    border-radius: 8px;
    background: var(--paper-surface);
    box-shadow: var(--paper-shadow);
  }

  .article-card {
    --article-content-max: 68ch;
    overflow: visible;
    padding: 0;
    border: 0;
    border-radius: 0;
    background: transparent;
    box-shadow: none;
  }

  .article-content {
    max-width: var(--article-content-max);
    color: var(--paper-ink);
    font-family: var(--font-article);
    font-size: 18px;
    line-height: 1.75;
    text-wrap: pretty;
  }

  .article-content :global(h2) {
    margin-top: 56px;
    margin-bottom: 20px;
    color: var(--paper-ink);
    font-size: 1.9rem;
    line-height: 1.2;
  }

  .article-content :global(h3) {
    margin-top: 38px;
    margin-bottom: 16px;
    color: var(--paper-ink);
    font-size: 1.35rem;
  }

  .article-content :global(p) {
    margin: 0 0 22px;
  }

  .article-content :global(a) {
    color: var(--paper-accent);
    font-weight: 700;
    text-decoration-color: rgba(102, 125, 109, 0.32);
    text-underline-offset: 4px;
  }

  .article-content :global(blockquote) {
    margin: 34px 0;
    padding: 18px 22px 18px 26px;
    border: 1px solid var(--paper-line);
    border-left: 3px solid rgba(102, 125, 109, 0.42);
    border-radius: 7px;
    background: var(--paper-surface-muted);
    color: var(--paper-ink);
    font-family: var(--font-article);
    font-size: 1.08rem;
  }

  .article-content :global(pre),
  .code-block {
    overflow-x: auto;
    border: 1px solid var(--paper-line-strong);
    border-radius: 7px;
    background: var(--paper-surface-muted);
    color: var(--paper-ink);
  }

  .article-content :global(pre) {
    padding: 20px;
  }

  .article-content :global(code) {
    font-family: var(--font-code);
    border-radius: 7px;
    background: var(--paper-control);
    color: var(--paper-ink);
  }

  .article-content :global(pre code) {
    background: transparent;
  }

  .code-block {
    font-family: var(--font-code);
    margin: 0;
    padding: 20px;
    font-size: 0.9rem;
  }

  .mobile-after-article {
    display: none;
  }

  @media (max-width: 1180px) {
    .blog-layout {
      grid-template-columns: minmax(0, 720px) 238px;
      justify-content: center;
      width: min(100%, 1040px);
    }
  }

  @media (max-width: 900px) {
    .blog-layout {
      display: block;
      max-width: 760px;
      padding: 88px 16px 36px;
    }

    .right-sidebar {
      display: none;
    }

    .mobile-after-article {
      display: grid;
      margin-top: 18px;
    }
  }

  @media (max-width: 640px) {
    .article-card {
      padding: 0;
      border-radius: 8px;
    }
  }
</style>
